{{ 'visual-search.css' | asset_url | stylesheet_tag }}

<div class="vs-page" data-visual-search>
  <div class="vs-content">
    <header class="vs-header">
      <p class="vs-eyebrow">JEWELLERY &bull; VISUAL SIMILARITY &bull; AI-POWERED</p>
      <h1 class="vs-heading">Find Similar Jewellery</h1>
    </header>

    <div class="vs-form">
      <div class="vs-form-grid">
        <div class="vs-upload-card" data-vs-dropzone>
          <div class="vs-upload-controls">
            <label class="vs-upload-btn" for="vs-file-input">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"></path>
                <polyline points="17 8 12 3 7 8"></polyline>
                <line x1="12" y1="3" x2="12" y2="15"></line>
              </svg>
              <span data-vs-upload-text>Upload</span>
              <input type="file" id="vs-file-input" accept="image/*" hidden data-vs-file-input>
            </label>
            <p class="vs-upload-hint">Up to 5 files &bull; JPG, PNG or PDF &bull; Max 10MB each</p>
          </div>

          <div class="vs-upload-preview" data-vs-preview hidden>
            <img data-vs-preview-img alt="Uploaded preview" width="400" height="400">
            <button type="button" class="vs-preview-remove" data-vs-remove aria-label="Remove image">
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <line x1="18" y1="6" x2="6" y2="18"></line>
                <line x1="6" y1="6" x2="18" y2="18"></line>
              </svg>
            </button>
          </div>
        </div>

        <div class="vs-controls-col">
          <div class="vs-field">
            <label for="vs-category">Category</label>
            <div class="vs-select-wrapper">
              <select id="vs-category" data-vs-category>
                <option value="" disabled selected>Select</option>
                <option value="ring">Ring</option>
                <option value="earring">Earring</option>
                <option value="necklace">Necklace</option>
                <option value="bracelet">Bracelet</option>
                <option value="bangle">Bangle</option>
                <option value="pendant">Pendant</option>
              </select>
              <svg class="vs-select-icon" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <polyline points="6 9 12 15 18 9"></polyline>
              </svg>
            </div>
          </div>

          <div class="vs-field">
            <label for="vs-count">Number of Result</label>
            <input
              type="range"
              id="vs-count"
              data-vs-count
              min="1"
              max="12"
              value="8"
              class="vs-slider"
              style="--vs-slider-fill: 64%;"
            >
          </div>
        </div>
      </div>

      <div class="vs-search-wrap">
        <button type="button" class="vs-search-btn" data-vs-search disabled>Search</button>
      </div>
    </div>

    <div class="vs-loading" data-vs-loading hidden>
      <div class="vs-spinner"></div>
      <p data-vs-loading-message>Analysing your image...</p>
      <div class="vs-progress" data-vs-progress hidden>
        <div class="vs-progress-bar" data-vs-progress-bar style="--vs-progress: 0%"></div>
      </div>
    </div>

    <div class="vs-error" data-vs-error role="alert" aria-live="polite" hidden>
      <p class="vs-error-message" data-vs-error-message></p>
      <div class="vs-error-actions">
        <button type="button" class="vs-error-retry" data-vs-error-retry hidden>Try again</button>
        <button type="button" class="vs-error-dismiss" data-vs-error-dismiss aria-label="Dismiss error">Dismiss</button>
      </div>
    </div>

    <section class="vs-results" data-vs-results>
      <h2 class="vs-results-heading">Visually Similar Results</h2>
      <div class="vs-grid" data-vs-grid>
        <div class="vs-card vs-card--placeholder"></div>
        <div class="vs-card vs-card--placeholder"></div>
        <div class="vs-card vs-card--placeholder"></div>
        <div class="vs-card vs-card--placeholder"></div>
        <div class="vs-card vs-card--placeholder"></div>
        <div class="vs-card vs-card--placeholder"></div>
        <div class="vs-card vs-card--placeholder"></div>
        <div class="vs-card vs-card--placeholder"></div>
      </div>
    </section>
  </div>
</div>

<script src="{{ 'visual-search.js' | asset_url }}" defer></script>

{% schema %}
{
  "name": "Visual Search",
  "settings": [],
  "presets": [
    {
      "name": "Visual Search"
    }
  ]
}
{% endschema %}
